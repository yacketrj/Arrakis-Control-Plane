# dune-admin configuration
# Copy to .env and run: go run . -setup   (or: ./dune-admin -setup)
# The setup wizard fills the SSH and database settings automatically.
#
# Security defaults:
# - SSH_KEY must be an Ed25519 private key.
# - SSH_KNOWN_HOSTS must contain the remote host's Ed25519 host key.
# - Add the host key with: ssh-keyscan -t ed25519 -H <host> >> ~/.ssh/known_hosts
# - ADMIN_TOKEN must be exactly 43 base64url characters generated from 32 random bytes.
# - LISTEN_ADDR must remain loopback unless DUNE_ADMIN_REMOTE_EXPOSURE is explicitly set.
# - Do not expose this backend directly to the public internet.

SSH_HOST=192.168.0.72:22
SSH_USER=dune
SSH_KEY=~/.ssh/dune_admin_ed25519
SSH_KNOWN_HOSTS=~/.ssh/known_hosts

SSH_TUNNEL_MODE=auto
SSH_TUNNEL_LOCAL_HOST=127.0.0.1
DB_TUNNEL_LOCAL_PORT=0

DB_PORT=15432
DB_USER=dune
DB_PASS=
DB_NAME=dune
DB_SCHEMA=dune

SCRIP_CURRENCY=1

ADMIN_TOKEN=
LISTEN_ADDR=127.0.0.1:8080
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Optional. Only use when the backend is protected by HTTPS/WSS and a trusted reverse proxy or VPN.
# DUNE_ADMIN_REMOTE_EXPOSURE=reverse-proxy-tls

# Optional Discord OAuth registration and role mapping.
# Admin-token authentication remains available as a break-glass path.
DISCORD_AUTH_ENABLED=false
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/v1/auth/discord/callback
DISCORD_POST_LOGIN_REDIRECT=http://localhost:5173
DISCORD_GUILD_ID=
DISCORD_ADMIN_ROLE_IDS=
DISCORD_NORMAL_ROLE_IDS=
DISCORD_USER_STORE=discord-users.json
SESSION_COOKIE_SECURE=false

# Optional Discord bot command plane. Keep disabled until configured with a least-privilege bot token.
DISCORD_BOT_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_BOT_GUILD_ID=
DISCORD_BOT_ADMIN_ROLE_IDS=
DISCORD_BOT_NORMAL_ROLE_IDS=
